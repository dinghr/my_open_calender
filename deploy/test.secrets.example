# AI 伴学小程序 - 测试环境 Secrets 示例
# 复制此文件为 /etc/ai-study/test.secrets 并填写真实值
# 权限设置：chmod 600 /etc/ai-study/test.secrets

# ==================== AI 服务配置 ====================

# Moonshot AI API 密钥（可以用测试密钥）
AI_API_KEY=sk-your-test-api-key-here

# ==================== 管理员配置 ====================

# 管理员用户名
ADMIN_USERNAME=test_admin

# 管理员密码（测试环境可以简单一些）
ADMIN_PASSWORD=test_password_123

# ==================== JWT 配置 ====================

# JWT 密钥
JWT_SECRET=test-jwt-secret-key-for-development-only

# JWT 过期时间（秒）
JWT_EXPIRATION=86400

# ==================== 其他配置 ====================

# 测试环境允许注册
ALLOW_REGISTRATION=true

# 测试环境文件上传限制更大
MAX_UPLOAD_SIZE=52428800

# 测试环境速率限制更宽松
RATE_LIMIT_PER_MINUTE=500
