# AI 伴学小程序 - 生产环境 Secrets 示例
# 复制此文件为 /etc/ai-study/prod.secrets 并填写真实值
# 权限设置：chmod 600 /etc/ai-study/prod.secrets

# ==================== AI 服务配置 ====================

# Moonshot AI API 密钥
AI_API_KEY=sk-your-production-api-key-here

# 可选：备用 AI 服务
# AI_BACKUP_API_KEY=sk-backup-key-here

# ==================== 管理员配置 ====================

# 管理员用户名
ADMIN_USERNAME=your_admin_username

# 管理员密码（请使用强密码）
ADMIN_PASSWORD=your_very_secure_password_here

# ==================== JWT 配置 ====================

# JWT 密钥（用于用户认证）
JWT_SECRET=your-random-jwt-secret-key-at-least-32-chars

# JWT 过期时间（秒）
JWT_EXPIRATION=86400

# ==================== 数据库加密（可选） ====================

# 如果启用数据库加密，请设置此密钥
# DB_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ==================== 邮件服务（可选） ====================

# SMTP 配置（用于发送通知）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=notifications@ai-study.com
# SMTP_PASSWORD=your-smtp-password

# ==================== 监控服务（可选） ====================

# Sentry DSN（错误追踪）
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456

# ==================== 其他配置 ====================

# 是否允许注册（生产环境可以关闭）
ALLOW_REGISTRATION=true

# 最大文件上传大小（字节）
MAX_UPLOAD_SIZE=10485760

# 速率限制（每分钟请求数）
RATE_LIMIT_PER_MINUTE=100
