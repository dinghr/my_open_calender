# 生产环境配置
VITE_APP_ENV=production
VITE_APP_TITLE=AI 伴学小程序
VITE_API_BASE_URL=https://api.yourdomain.com/api
VITE_DB_PATH=/home/ecs-user/my_open_calender/data/prod.db
VITE_ENABLE_DEBUG=false
VITE_LOG_LEVEL=error

# AI 配置（生产用）
VITE_AI_MODEL=moonshot-v1-32k
VITE_AI_BASE_URL=https://api.moonshot.cn/v1

# 管理员配置（从环境变量读取）
VITE_ADMIN_USERNAME=${ADMIN_USERNAME}
VITE_ADMIN_PASSWORD=${ADMIN_PASSWORD}

# 功能开关
VITE_ENABLE_PRINT=true
VITE_ENABLE_VOICE=true
