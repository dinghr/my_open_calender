# 后端生产环境配置
APP_ENV=production
DEBUG=false
LOG_LEVEL=error

# 数据库配置
DB_PATH=/home/ecs-user/my_open_calender/data/prod.db

# API 配置
HOST=0.0.0.0
PORT=8000

# API 域名限制
ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# AI 服务配置（生产用）
AI_MODEL=moonshot-v1-32k
AI_BASE_URL=https://api.moonshot.cn/v1
# AI_API_KEY=从 secrets 管理读取

# 管理员配置（从环境变量或 secrets 读取）
ADMIN_USERNAME=${ADMIN_USERNAME}
ADMIN_PASSWORD=${ADMIN_PASSWORD}

# 功能开关
ENABLE_PRINT=true
ENABLE_VOICE=true
